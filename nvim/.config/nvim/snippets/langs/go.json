{
  "Initiate go file": {
    "prefix": ["init", "goinit"],
    "body": ["package ${1:main}", "", "", "func main(){", "\t$0", "}"],
    "description": "Print something"
  },
  "Print format something": {
    "prefix": ["cl", "ll", "pr", "log", "echo"],
    "body": ["fmt.Printf(\"💀 $2 -> %${3:#v}\\n\", $1)$0"],
    "description": "Print format something"
  },
  "Print line something": {
    "prefix": ["lln", "cln", "logn", "println", "echon"],
    "body": ["fmt.Println(\"💀 $2 -> \", $1)$0"],
    "description": "Print something"
  },
  "Print here": {
    "prefix": ["here"],
    "body": ["fmt.Println(\"💀 -------------> HERE $1 \")$0"],
    "description": "Print here"
  },
  "Print separator": {
    "prefix": ["sep"],
    "body": ["fmt.Println(\"💀 ------------------- 💀\")$0"],
    "description": "Print separator"
  },
  "Single constant": {
    "prefix": "cn",
    "body": "const ${1:name} = ${2:value}",
    "description": "Snippet for a constant"
  },
  "Multiple constants": {
    "prefix": "cns",
    "body": "const (\n\t${1:name} = ${2:value}\n)",
    "description": "Snippet for a constant block"
  },
  "Function declaration": {
    "prefix": "fn",
    "body": "func $1($2) $3 {\n\t$0\n}",
    "description": "Snippet for function declaration"
  },
  "if err != nil": {
    "prefix": "iferr",
    "body": "if err != nil {\n\treturn ${2:err}\n}",
    "description": "Snippet for if err != nil"
  },
  "unimplemented panic fn": {
    "prefix": ["unimpl"],
    "body": "panic(\"Not Implemented\")",
    "description": "Snippet for unimplemented panic fn"
  },
  "method declaration": {
    "prefix": "mtd",
    "body": "func (${1:receiver} *${2:type}) ${3:method}($4) $5 {\n\t$0\n}",
    "description": "Snippet for method declaration"
  }
}
